# Outbound Assistant — copy this file to ".env" and fill in your credentials

# LLM
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_SKIP_SIG_VALIDATION=false (#true = local testing only, false = real calls (default))

# Transport (true = real Twilio call, false = Gradio debug mode)
ENABLE_TWILIO_TRANSPORT=true

# Session tuning
LOG_DIR=./logs
MAX_TURNS_BEFORE_ESCALATION=10
MAX_SILENCE_SECONDS=8
LLM_TIMEOUT_SECONDS=20

# Servers
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
GRADIO_SERVER_HOST=127.0.0.1
GRADIO_SERVER_PORT=7860
ENABLE_GRADIO_DEBUG=true
