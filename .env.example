# =============================================================================
# Outbound Assistant — environment template
# Copy to ".env" and fill in values. Never commit ".env".
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (Groq) — required for instruction parsing and agent replies
# Get a key: https://console.groq.com/keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# Twilio Programmable Voice — required only when ENABLE_TWILIO_TRANSPORT=true
# Console: https://console.twilio.com/
# You need: Account SID, Auth Token (or API key for production), Voice-capable number
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Full URL Twilio POSTs call status / AMD callbacks to (must be publicly reachable when testing real calls).
# Example: https://abcd1234.ngrok-free.app/webhooks/twilio/status
# Voice TwiML and Gather action URLs are derived as sibling paths (.../voice, .../action).
TWILIO_STATUS_CALLBACK_URL=

# Optional: wss URL for Media Streams if you extend the WebSocket path (not required for Say+Gather flow).
TWILIO_STREAM_URL=

# Set true only for local automated tests or debugging without valid X-Twilio-Signature.
# Use false in any environment exposed to the internet.
TWILIO_SKIP_SIG_VALIDATION=false

# -----------------------------------------------------------------------------
# Transport selection
# false = Gradio debug transport (no real phone; good for graph / session tests)
# true  = Twilio outbound calls (requires all TWILIO_* URLs and credentials above)
# -----------------------------------------------------------------------------
ENABLE_TWILIO_TRANSPORT=false

# -----------------------------------------------------------------------------
# Session / conversation tuning
# -----------------------------------------------------------------------------
LOG_DIR=./logs
MAX_TURNS_BEFORE_ESCALATION=10
MAX_SILENCE_SECONDS=8
LLM_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Local servers
# -----------------------------------------------------------------------------
ENABLE_GRADIO_DEBUG=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
GRADIO_SERVER_HOST=127.0.0.1
GRADIO_SERVER_PORT=7860
